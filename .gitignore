# Generated frontend build artifacts (rebuilt by Docker / npm run build)
# index.html is NOT excluded — a stub is committed so pytest /dashboard returns 200.
# The Docker multi-stage build overwrites it with the real Vite output.
app/static/assets/
app/static/cesium/

# SQLite database (ephemeral; regenerated at runtime)
ionshield.db

# Frontend tooling
frontend/node_modules/
frontend/.playwright/
frontend/test-results/
frontend/playwright-report/
