<?xml version="1.0" encoding="utf-8"?>
<!--
  IonShield ATAK plugin manifest — placeholder for the Android dev to
  customise. The required ATAK plugin metadata lives in <meta-data> tags
  consumed by ATAK at plugin-load time.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ionshield.atak"
    android:versionCode="1"
    android:versionName="0.1.0">

    <uses-sdk android:minSdkVersion="26" android:targetSdkVersion="34" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application android:label="@string/app_name"
                 android:hasCode="true"
                 android:icon="@drawable/ic_launcher"
                 android:theme="@android:style/Theme.NoTitleBar">

        <!-- ATAK plugin discovery: required meta-data keys -->
        <meta-data android:name="atakplugin.api.version" android:value="1.0" />
        <meta-data android:name="atakplugin.id"          android:value="com.ionshield.atak" />
        <meta-data android:name="atakplugin.title"       android:value="@string/app_name" />
        <meta-data android:name="atakplugin.description" android:value="@string/plugin_description" />
        <meta-data android:name="atakplugin.entry"       android:value="com.ionshield.atak.IonShieldPlugin" />

    </application>
</manifest>
