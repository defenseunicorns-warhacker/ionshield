    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "cesium": "^1.114.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.2.1",
    "jsdom": "^23.0.1",
    "vite": "^5.0.10",
    "vite-plugin-cesium": "^1.2.22",
    "vitest": "^1.1.3"
  }
}
