# IonShield Backend — Environment Variables
# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# ── Authentication ─────────────────────────────────────────────────────────
# Set to a strong random string to require X-API-Key header on all requests.
# Leave empty to run in open/unauthenticated mode (local dev or internal net).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated allowed origins, or * for open access.
# Example: CORS_ORIGINS=https://ionshield.yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# ── Data refresh ───────────────────────────────────────────────────────────
# How often (seconds) to re-fetch NOAA data. Default: 300 (5 min).
REFRESH_INTERVAL_SECONDS=300

# HTTP timeout per NOAA request (seconds)
NOAA_TIMEOUT_SECONDS=10.0

# ── Rate limiting ──────────────────────────────────────────────────────────
# slowapi rate limit string. Format: "N/period" where period = second/minute/hour.
RATE_LIMIT=120/minute

# ── Validation ─────────────────────────────────────────────────────────────
MAX_ROUTE_WAYPOINTS=200

# ── Logging ────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Configurable locations ──────────────────────────────────────────────────
# Path to locations JSON file (relative to working directory).
# Copy locations.example.json → locations.json and edit to add your sites.
# If this file doesn't exist, location monitoring is silently disabled.
LOCATIONS_FILE=locations.json

# Global alert threshold. Per-location overrides in locations.json take priority.
# Values: NOMINAL | ELEVATED | DEGRADED | SEVERE
ALERT_THRESHOLD=ELEVATED

# ── ATAK CoT push ───────────────────────────────────────────────────────────
# Push CoT XML events to a TAK server when locations enter alert state.
# Leave COT_SERVER_HOST empty to disable push; the pull feed always works.
# Example: COT_SERVER_HOST=tak.yournet.mil
COT_SERVER_HOST=
COT_SERVER_PORT=8087
COT_STALE_MINUTES=10
